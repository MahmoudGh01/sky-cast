{
  "name": "skycast",
  "type": "module",
  "main": "expo-router/entry",
  "imports": {
    "#shared/*": "./src/shared/*/index.ts",
    "#design/*": "./src/shared/design/*/index.ts"
  },
  "version": "1.0.0",
  "scripts": {
    "lint": "npm run lint-typecheck && npm run lint-eslint && npm run lint-prettier && npm run lint-knip",
    "lint-typecheck": "tsc --noEmit",
    "lint-eslint": "eslint .",
    "lint-prettier": "prettier --check .",
    "lint-knip": "knip",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage",
    "test:coverage": "jest --coverage",
    "build": "eas build --platform android --non-interactive --no-wait",
    "start": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.0",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.17",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.9",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@christopherjbaker/eslint-config": "^3.1.4",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^30.4.1",
    "babel-preset-expo": "^56.0.14",
    "eslint": "^9.39.4",
    "eslint-plugin-expo": "^1.0.3",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "knip": "^6.14.1",
    "prettier": "^3.8.3",
    "react-test-renderer": "^19.1.0",
    "typescript": "~6.0.3"
  },
  "private": true
}
