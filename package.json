{
  "name": "skycast",
  "type": "module",
  "main": "expo-router/entry",
  "imports": {
    "#shared/*": "./src/shared/*/index.ts",
    "#design/*": "./src/shared/design/*/index.ts"
  },
  "version": "1.0.0",
  "scripts": {
    "lint": "npm run lint-typecheck && npm run lint-eslint && npm run lint-prettier && npm run lint-knip",
    "lint-typecheck": "tsc --noEmit",
    "lint-eslint": "eslint .",
    "lint-prettier": "prettier --check .",
    "lint-knip": "knip",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage",
    "test:coverage": "jest --coverage",
    "build": "eas build --platform android --non-interactive --no-wait",
    "start": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/drawer": "^7.10.2",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@christopherjbaker/eslint-config": "^3.1.4",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^30.4.1",
    "babel-preset-expo": "^56.0.14",
    "eas-cli": "^20.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-expo": "^1.0.3",
    "jest": "^29.7.0",
    "jest-expo": "^52.0.0",
    "knip": "^6.14.1",
    "prettier": "^3.8.3",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
